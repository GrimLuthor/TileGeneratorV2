<Window x:Class="TileGeneratorV2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tile Generator v2" Height="700" Width="960"
        Background="#1E1E1E" ResizeMode="CanResize" MinWidth="800" MinHeight="560">

    <Window.Resources>

        <!-- ── Text / input styles ── -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="CaretBrush" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#1E5080"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- ── Dark ComboBox ── -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2D2D2D"/>
                        <Setter Property="Foreground" Value="#EEEEEE"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#2A6099"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A4070"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Closed-state display -->
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Margin="7,5"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    <Path Grid.Column="1" Data="M0,0 L5,4 L10,0"
                                          Stroke="#888" StrokeThickness="1.5"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <!-- Transparent toggle covers the whole header row -->
                            <ToggleButton Focusable="False" Background="Transparent" BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"/>

                            <!-- Dropdown popup -->
                            <Popup x:Name="PART_Popup" AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" Focusable="False" PopupAnimation="None">
                                <Border Background="#2D2D2D" BorderBrush="#555555" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ComboBox}}">
                                    <ScrollViewer MaxHeight="220" Background="#2D2D2D"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="215" MinWidth="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Left panel ══ -->
        <StackPanel Grid.Column="0" Margin="0,0,12,0">

            <TextBlock Text="TILE GENERATOR v2" Foreground="#6AABFF"
                       FontWeight="Bold" FontSize="13" Margin="0,0,0,12"/>

            <!-- Seed -->
            <TextBlock Style="{StaticResource Label}" Text="SEED"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SeedBox" Style="{StaticResource Input}" Text="42"
                         KeyDown="SeedBox_KeyDown"/>
                <Button Grid.Column="1" Style="{StaticResource SmallBtn}" Content="?" Margin="4,0,0,0"
                        ToolTip="Random seed + colors" Click="RandomizeSeed_Click"/>
            </Grid>

            <!-- ── Colors ── -->
            <TextBlock Foreground="#444" Margin="0,14,0,0" Text="───────────────"/>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Foreground="#888" FontSize="10" FontWeight="Bold" Text="COLORS"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource SmallBtn}" Content="? Colors"
                        ToolTip="Pick a random harmonious palette" Click="RandomizeColors_Click"/>
            </Grid>

            <TextBlock Style="{StaticResource Label}" Text="Hue 1  (0–360°)"/>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="26"/></Grid.ColumnDefinitions>
                <TextBox x:Name="Hue1Box" Style="{StaticResource Input}" Text="30" TextChanged="ColorBox_TextChanged"/>
                <Border x:Name="Hue1Preview" Grid.Column="1" Margin="4,0,0,0" BorderBrush="#555" BorderThickness="1"/>
            </Grid>

            <TextBlock Style="{StaticResource Label}" Text="Hue 2  (0–360°)"/>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="26"/></Grid.ColumnDefinitions>
                <TextBox x:Name="Hue2Box" Style="{StaticResource Input}" Text="26" TextChanged="ColorBox_TextChanged"/>
                <Border x:Name="Hue2Preview" Grid.Column="1" Margin="4,0,0,0" BorderBrush="#555" BorderThickness="1"/>
            </Grid>

            <TextBlock Style="{StaticResource Label}" Text="Saturation  (0–100%)"/>
            <TextBox x:Name="SatBox" Style="{StaticResource Input}" Text="48" TextChanged="ColorBox_TextChanged"/>

            <TextBlock Style="{StaticResource Label}" Text="Light  (0–100%)"/>
            <TextBox x:Name="LightBox" Style="{StaticResource Input}" Text="62" TextChanged="ColorBox_TextChanged"/>

            <TextBlock Style="{StaticResource Label}" Text="Dark  (0–100%)"/>
            <TextBox x:Name="DarkBox" Style="{StaticResource Input}" Text="14" TextChanged="ColorBox_TextChanged"/>

            <!-- ── Material ── -->
            <TextBlock Foreground="#444" Margin="0,14,0,0" Text="───────────────"/>
            <TextBlock Foreground="#888" FontSize="10" FontWeight="Bold" Margin="0,4,0,0" Text="MATERIAL"/>

            <TextBlock Style="{StaticResource Label}" Text="Type"/>
            <ComboBox x:Name="MaterialCombo" Style="{StaticResource DarkCombo}" SelectedIndex="0">
                <ComboBoxItem>Auto (seed-driven)</ComboBoxItem>
                <ComboBoxItem>Cobblestone</ComboBoxItem>
                <ComboBoxItem>Marble</ComboBoxItem>
                <ComboBoxItem>Granite</ComboBoxItem>
                <ComboBoxItem>Smooth Stone</ComboBoxItem>
                <ComboBoxItem>Rough</ComboBoxItem>
                <ComboBoxItem>Layered</ComboBoxItem>
                <ComboBoxItem>Cracked</ComboBoxItem>
                <ComboBoxItem>Cellular</ComboBoxItem>
                <ComboBoxItem>Wavy</ComboBoxItem>
                <ComboBoxItem>Ridged</ComboBoxItem>
                <ComboBoxItem>Wood</ComboBoxItem>
                <ComboBoxItem>Contour</ComboBoxItem>
                <ComboBoxItem>Composite</ComboBoxItem>
            </ComboBox>

            <!-- Generate -->
            <TextBlock Foreground="#444" Margin="0,14,0,0" Text="───────────────"/>
            <Button x:Name="GenerateBtn" Style="{StaticResource PrimaryBtn}"
                    Content="Generate" Click="Generate_Click" Margin="0,6,0,0"/>

            <TextBlock x:Name="StatusLabel" Foreground="#666" FontSize="10"
                       Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ══ Right panel: previews ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Wall previews -->
            <TextBlock Grid.Row="0" Foreground="#555" FontSize="10" Margin="0,0,0,6">
                <Run Foreground="#6AABFF" Text="WALL  "/>
                <Run Text="SINGLE TILE  4×zoom"/>
                <Run Text="                        "/>
                <Run Text="TILING PREVIEW  4×4 tiles · 2×zoom"/>
            </TextBlock>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#333" BorderThickness="1" VerticalAlignment="Top">
                    <Image x:Name="SingleTileImage" Width="128" Height="128"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" Stretch="None"/>
                </Border>

                <Border Grid.Column="1" Margin="16,0,0,0" BorderBrush="#333" BorderThickness="1"
                        VerticalAlignment="Top" HorizontalAlignment="Left">
                    <Image x:Name="TilingPreviewImage" Width="256" Height="256"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" Stretch="None"/>
                </Border>
            </Grid>

            <!-- Floor previews -->
            <TextBlock Grid.Row="2" Foreground="#555" FontSize="10" Margin="0,0,0,6">
                <Run Foreground="#6AABFF" Text="FLOOR  "/>
                <Run Text="SINGLE TILE  4×zoom"/>
                <Run Text="                        "/>
                <Run Text="TILING PREVIEW  4×4 tiles · 2×zoom"/>
            </TextBlock>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#333" BorderThickness="1" VerticalAlignment="Top">
                    <Image x:Name="FloorSingleTileImage" Width="128" Height="128"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" Stretch="None"/>
                </Border>

                <Border Grid.Column="1" Margin="16,0,0,0" BorderBrush="#333" BorderThickness="1"
                        VerticalAlignment="Top" HorizontalAlignment="Left">
                    <Image x:Name="FloorTilingPreviewImage" Width="256" Height="256"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" Stretch="None"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
